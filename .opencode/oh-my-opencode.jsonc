{
    "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
    "agents": {
        "test-writer": {
            "variant": "high",
            "temperature": 0.05,
            "thinking": {
                "type": "enabled",
                "budgetTokens": 15000
            },
            "permission": {
                "edit": "allow",
                "write": "allow",
                "bash": {
                    "godot* *--headless* *--path*": "allow",
                    "godot* *--scene*": "allow",
                    "ls *": "allow",
                    "cat *": "allow",
                    "*": "ask"
                },
                "task": "deny"
            },
            "prompt_append": "Always generate complete, runnable GDScript with zero placeholder comments. Every test must pass validation checklist before being considered done."
        },
        "test-runner": {
            "variant": "medium",
            "temperature": 0.0,
            "thinking": {
                "type": "enabled",
                "budgetTokens": 8000
            },
            "permission": {
                "edit": "deny",
                "write": "deny",
                "bash": {
                    "godot* *--headless* *--path*": "allow",
                    "godot* *--scene*": "allow",
                    "cat *": "allow",
                    "grep *": "allow",
                    "find *": "allow",
                    "head *": "allow",
                    "wc -l *": "allow",
                    "echo *": "allow",
                    "*": "deny"
                },
                "task": "deny"
            },
            "prompt_append": "Output structured results when possible. Be precise and evidence-based about failure root causes. Always include the actual Godot stderr output in failure reports."
        }
    },
    "claude_code": {
        "agents": true
    }
}