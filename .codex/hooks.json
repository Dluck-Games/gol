{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/hooks/block-gdunit-in-integration.sh\"",
            "statusMessage": "Checking integration test base class",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/hooks/block-sceneconfig-in-unit.sh\"",
            "statusMessage": "Checking unit test base class",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/hooks/block-pull-submodule-code-in-parent.sh\"",
            "statusMessage": "Checking submodule command",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/hooks/block-original-png-in-gol-project.sh\"",
            "statusMessage": "Checking image placement",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/hooks/validate-art-placement.sh\"",
            "statusMessage": "Checking art placement",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.agents/hooks/gdscript-lsp-check.mjs\"",
            "statusMessage": "Checking GDScript diagnostics",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/hooks/godot-auto-uid.sh\"",
            "statusMessage": "Refreshing Godot UIDs",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
